# =============================================================================
# oMLX CLI / Web 环境变量模板（逐项注释）
# -----------------------------------------------------------------------------
# 使用方式：
#   1. 复制本文件为仓库根目录下的 `.env.local`（推荐，已在 .gitignore）或 `.env`
#   2. 取消注释并填写需要的项；未设置的项使用代码内默认值
#   3. 启动：`./start_web.sh` 会 source `.env` / `.env.local`；直接 `uvicorn` 时
#      `webapi/app.py` 会在导入阶段自动加载同路径的 `.env`、`.env.local`
# 覆盖规则：调用加载**之前**进程环境里已存在的键不会被文件改写；同一键在 .env 与
# .env.local 均出现时，以 .env.local 为准（便于本地覆盖默认模板）。
# =============================================================================

# -----------------------------------------------------------------------------
# 一、Web 监听（由 start_web.sh 读取；纯 uvicorn 命令行参数优先生效）
# -----------------------------------------------------------------------------
# OMLXCLI_HOST=127.0.0.1
# OMLXCLI_PORT=8788

# -----------------------------------------------------------------------------
# 二、数据目录与工作区
# -----------------------------------------------------------------------------
# SQLite 与会话数据目录（默认：<repo>/.omlxcli/web）
# OMLXCLI_DATA_DIR=

# 新会话默认工作目录，shell 命令 cwd 以此为边界之一（默认：仓库根）
# OMLXCLI_DEFAULT_WORKSPACE=

# -----------------------------------------------------------------------------
# 三、上游模型（OpenAI-compatible，与 oi 兼容命名）
# -----------------------------------------------------------------------------
# OI_MODEL=Qwen3.5-35B-A3B-8bit
# OI_API_BASE=http://127.0.0.1:8000/v1
# OI_API_KEY=

# 拉取 /v1/models 列表的超时（秒）
# OMLXCLI_MODELS_LIST_TIMEOUT_SEC=8

# Chat Completions HTTP 超时（秒）
# OMLXCLI_CHAT_TIMEOUT_SEC=120
# 上游 5xx 等可重试次数上限（0～8）
# OMLXCLI_CHAT_HTTP_RETRIES=2
# 重试间隔基数（秒），实际会递增
# OMLXCLI_CHAT_RETRY_BACKOFF_SEC=0.5

# 首选模型不可用（如 404）时的回退列表，逗号分隔模型 id
# OMLXCLI_MODEL_FALLBACKS=

# -----------------------------------------------------------------------------
# 四、Skills 目录与 run_skill 超时
# -----------------------------------------------------------------------------
# 自定义 skills 根目录（须含 manifests/skills.json）
# OMLXCLI_SKILLS_DIR=

# 单次 run_skill 执行上限（秒）。0 或负数表示不限制（不推荐生产）。
# 超时后返回错误信息；底层线程可能仍在运行直至技能代码结束，请勿依赖其可杀进程语义。
# OMLXCLI_RUN_SKILL_TIMEOUT_SEC=120

# -----------------------------------------------------------------------------
# 五、联网搜索（web_search skill）
# -----------------------------------------------------------------------------
# 推荐：SearXNG v2 网关 Base URL
# OMLXCLI_SEARCH_GATEWAY_URL=
# OMLXCLI_SEARCH_GATEWAY_USER=
# OMLXCLI_SEARCH_GATEWAY_PASSWORD=

# 直连 SearXNG 实例（网关不可用时备用）
# OMLXCLI_SEARXNG_URL=

# -----------------------------------------------------------------------------
# 六、会话引擎：上下文预算与自动摘要（checkpoint）
# -----------------------------------------------------------------------------
# 估算的上下文字符预算下限裁剪为 >=4096
# OMLXCLI_CONTEXT_BUDGET_CHARS=24000
# 超过 预算×该比例 时更易触发摘要 checkpoint（0.5～0.99）
# OMLXCLI_SUMMARY_TRIGGER_RATIO=0.82
# 两次自动摘要之间至少间隔的用户消息轮数
# OMLXCLI_SUMMARY_MIN_MESSAGES_BETWEEN=6

# 代理每会话最大「执行轮数」（run_shell/run_skill 循环），1～24
# OMLXCLI_MAX_EXEC_ROUNDS=8

# 非空且为 1/true/yes/on 时启用多 Agent 轻量扩展（见 session_engine）
# OMLXCLI_MULTI_AGENT=

# -----------------------------------------------------------------------------
# 七、执行策略（run_shell）
# -----------------------------------------------------------------------------
# 模板：strict / readonly / dev（组合黑名单、高风险、是否强制工作区边界等）
# OMLXCLI_EXEC_POLICY_TEMPLATE=

# 若设置则覆盖模板推断的 mode（如 readonly 模板下仍想 strict mutating 时可设）
# OMLXCLI_EXEC_POLICY_MODE=

# 以下正则均可选；留空则用模板默认值
# OMLXCLI_EXEC_BLOCKLIST_RE=
# OMLXCLI_EXEC_HIGH_RISK_RE=
# OMLXCLI_EXEC_MUTATING_RE=

# 写路径越界检查：1/true 启用（dev 模板默认常关，以模板为准）
# OMLXCLI_EXEC_ENFORCE_WORKSPACE_BOUNDARY=

# 非空时：命令行须匹配该正则子串才允许执行（白名单）
# OMLXCLI_EXEC_ALLOWLIST_RE=

# -----------------------------------------------------------------------------
# 八、管理 / 审计
# -----------------------------------------------------------------------------
# 设置后启用 GET /api/admin/sessions/{id}/audit-export，请求头 X-Admin-Token 须一致
# OMLXCLI_ADMIN_TOKEN=

# -----------------------------------------------------------------------------
# 九、测试与 CI（一般仅 CI 或本机刻意设置）
# -----------------------------------------------------------------------------
# 为 1/true/yes/on 时跳过 needs_outbound_http 类 agent 评测（避免外网抖动）
# OMLXCLI_EVAL_SKIP_HTTP=

# -----------------------------------------------------------------------------
# 十、多模态 skills 内部可选（_media.py 等，与 OI_* 二选一）
# -----------------------------------------------------------------------------
# _AICLI_API_BASE=
# _AICLI_API_KEY=
# _AICLI_LLM_MODEL=
# _AICLI_STT_MODEL=
# 语音转写可选用（与 _AICLI_STT_MODEL 二选）
# OI_STT_MODEL=
