## oMLX CLI local env template
## 复制为 .env 或 .env.local 后按需修改

# Web 启动参数
OMLXCLI_HOST=127.0.0.1
OMLXCLI_PORT=8788

# 上游模型服务（可选）
# OI_MODEL=Qwen3.5-35B-A3B-8bit
# OI_API_BASE=http://127.0.0.1:8000/v1
# OI_API_KEY=

# 搜索网关（推荐：SearXNG v2 gateway）
# 例：https://dog.lqai.cn
OMLXCLI_SEARCH_GATEWAY_URL=
OMLXCLI_SEARCH_GATEWAY_USER=
OMLXCLI_SEARCH_GATEWAY_PASSWORD=

# 直连 SearXNG（gateway 不可用时可作为备用）
# 例：http://127.0.0.1:8080
OMLXCLI_SEARXNG_URL=
