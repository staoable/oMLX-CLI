# =============================================================================
# oMLX CLI / Web 环境变量模板（逐项注释）
# -----------------------------------------------------------------------------
# 使用方式：
#   1. 复制本文件为仓库根目录下的 `.env.local`（推荐，已在 .gitignore）或 `.env`
#   2. 取消注释并填写需要的项；未设置的项使用代码内默认值
#   3. 启动：`./start_web.sh` 会 source `.env` / `.env.local`；直接 `uvicorn` 时
#      `webapi/app.py` 会在导入阶段自动加载同路径的 `.env`、`.env.local`
# 覆盖规则：调用加载**之前**进程环境里已存在的键不会被文件改写；同一键在 .env 与
# .env.local 均出现时，以 .env.local 为准（便于本地覆盖默认模板）。
# =============================================================================

# -----------------------------------------------------------------------------
# 一、Web 监听（由 start_web.sh 读取；纯 uvicorn 命令行参数优先生效）
# -----------------------------------------------------------------------------
# OMLXCLI_HOST=127.0.0.1
# OMLXCLI_PORT=8788
# 浏览器访问 Web UI 时 API 的 CORS 允许来源（逗号分隔）。留空则默认本机 8788。
# OMLXCLI_CORS_ORIGINS=http://127.0.0.1:8788,http://localhost:8788

# -----------------------------------------------------------------------------
# 二、数据目录与工作区
# -----------------------------------------------------------------------------
# SQLite 与会话数据目录（默认：<repo>/.omlxcli/web）
# OMLXCLI_DATA_DIR=

# 新会话默认工作目录，shell 命令 cwd 以此为边界之一（默认：仓库根）
# OMLXCLI_DEFAULT_WORKSPACE=

# -----------------------------------------------------------------------------
# 三、对话 HTTP 行为（与会话 model 占位回退由代码常量 + SQLite 模型设置决定）
# -----------------------------------------------------------------------------
# Web 的 API Base / API Key / 推理端点均在界面「模型设置」写入 SQLite（vendors 表），
# **无需**在本文件配置 OI_API_BASE / OI_API_KEY / OI_MODEL。
# 新建会话默认 model id、旧占位名 local/default/空 的回退：见代码 `DEFAULT_SESSION_MODEL_ID`；
# 若会话已绑定模型设置，占位时优先使用该条的 `default_model`。

# 拉取 /v1/models 列表的超时（秒）
# OMLXCLI_MODELS_LIST_TIMEOUT_SEC=8

# Chat Completions HTTP 超时（秒）
# OMLXCLI_CHAT_TIMEOUT_SEC=120
# 上游 5xx 等可重试次数上限（0～8）
# OMLXCLI_CHAT_HTTP_RETRIES=2
# 重试间隔基数（秒），实际会递增
# OMLXCLI_CHAT_RETRY_BACKOFF_SEC=0.5

# 首选模型不可用（如 404）时的回退列表，逗号分隔模型 id
# OMLXCLI_MODEL_FALLBACKS=

# 上游 LLM 协议：chat（默认，POST /v1/chat/completions）| completions（POST /v1/completions，由 messages 拼 prompt）
# | auto（先 chat，若整条请求最终以 HTTP 404/405/501 失败再尝试 completions；纯文本多轮可工作，多模态仅保留文本段）
# OMLXCLI_UPSTREAM_PROTOCOL=chat

# -----------------------------------------------------------------------------
# 四、Skills 目录与 run_skill 超时
# -----------------------------------------------------------------------------
# 自定义 skills 根目录（须含 manifests/skills.json）
# OMLXCLI_SKILLS_DIR=

# 单次 run_skill 执行上限（秒）。0 或负数表示不限制（不推荐生产）。
# 超时后返回错误信息；底层线程可能仍在运行直至技能代码结束，请勿依赖其可杀进程语义。
# OMLXCLI_RUN_SKILL_TIMEOUT_SEC=120
# 多模态本地缓存（.omlxcli/cache）保留时长与清理间隔（秒）
# OMLXCLI_MEDIA_CACHE_TTL_SEC=259200
# OMLXCLI_MEDIA_CACHE_CLEANUP_INTERVAL_SEC=900
#
# 表格 / Office 类 skills（csv_tsv_summary、xlsx_sample、structured_pick、docx_to_text）依赖根目录
# requirements.txt 中的 openpyxl、PyYAML、python-docx；与 Web 密钥无关，随 pip/bootstrap 安装即可。

# -----------------------------------------------------------------------------
# 五、联网搜索（web_search skill）
# -----------------------------------------------------------------------------
# 推荐：SearXNG v2 网关 Base URL
# OMLXCLI_SEARCH_GATEWAY_URL=
# OMLXCLI_SEARCH_GATEWAY_USER=
# OMLXCLI_SEARCH_GATEWAY_PASSWORD=

# 直连 SearXNG 实例（网关不可用时备用）
# OMLXCLI_SEARXNG_URL=

# -----------------------------------------------------------------------------
# 六、会话引擎：上下文预算与自动摘要（checkpoint）
# -----------------------------------------------------------------------------
# 估算的上下文字符预算下限裁剪为 >=4096
# OMLXCLI_CONTEXT_BUDGET_CHARS=24000
# 超过 预算×该比例 时更易触发摘要 checkpoint（0.5～0.99）
# OMLXCLI_SUMMARY_TRIGGER_RATIO=0.82
# 两次自动摘要之间至少间隔的用户消息轮数
# OMLXCLI_SUMMARY_MIN_MESSAGES_BETWEEN=6

# 代理每会话最大「执行轮数」（run_shell/run_skill 循环），1～24
# OMLXCLI_MAX_EXEC_ROUNDS=8
# 对话发送限流：同一会话+IP 在窗口期内允许的请求数（默认 20 次/60 秒）
# OMLXCLI_MSG_RATE_LIMIT_COUNT=20
# OMLXCLI_MSG_RATE_LIMIT_WINDOW_SEC=60
# 单请求体与附件总量上限（字节；超限返回 413）
# 说明：附件以 JSON + data URL（base64）随 POST 发送，实际请求体约为「文本 + 附件编码」；
# 故 OMLXCLI_MSG_MAX_BODY_BYTES 通常须明显大于「单文件原始字节数」。
# Web UI 单文件选择上限与下列项对齐：启动时 GET /api/ui-config 读取 msg_max_attachment_each_bytes（无需改前端）。
#
# 代码硬上限（见 webapi/app.py `_MSG_HARD_MAX_BYTES`）：上述三项经环境变量配置后，每项最大不超过 1 GiB（1073741824 字节）。
# 默认值（未设置 env 时）：body 约 5MB、附件合计约 6MB（见 webapi/app.py 内默认字面量）。
# OMLXCLI_MSG_MAX_BODY_BYTES=5242880
# OMLXCLI_MSG_MAX_ATTACHMENTS_BYTES=6291456
#
# 单附件上限（字节，可选）：不设时服务端取 min(OMLXCLI_MSG_MAX_ATTACHMENTS_BYTES, floor(OMLXCLI_MSG_MAX_BODY_BYTES×0.65))，为 base64 留出余量。
# OMLXCLI_MSG_MAX_ATTACHMENT_EACH_BYTES=
#
# 示例（本地/内网允许较大附件；仍受 1 GiB 硬上限与反代 body 限制约束）：
# OMLXCLI_MSG_MAX_BODY_BYTES=1073741824
# OMLXCLI_MSG_MAX_ATTACHMENTS_BYTES=1073741824
# OMLXCLI_MSG_MAX_ATTACHMENT_EACH_BYTES=697932185
#
# Web UI 视频附件：服务端用 ffmpeg 均匀抽帧为 JPEG 再作为 image_url 送入模型（多数上游不支持 input_video）。
# OMLXCLI_VIDEO_ATTACH_FRAMES=12
# OMLXCLI_VIDEO_ATTACH_MAX_BYTES=268435456

# 非空且为 1/true/yes/on 时启用多 Agent 轻量扩展（见 session_engine）
# OMLXCLI_MULTI_AGENT=

# -----------------------------------------------------------------------------
# 七、执行策略（run_shell）
# -----------------------------------------------------------------------------
# 模板：strict / readonly / dev（组合黑名单、高风险、是否强制工作区边界等）
# OMLXCLI_EXEC_POLICY_TEMPLATE=

# 若设置则覆盖模板推断的 mode（如 readonly 模板下仍想 strict mutating 时可设）
# OMLXCLI_EXEC_POLICY_MODE=

# 以下正则均可选；留空则用模板默认值
# OMLXCLI_EXEC_BLOCKLIST_RE=
# OMLXCLI_EXEC_HIGH_RISK_RE=
# OMLXCLI_EXEC_MUTATING_RE=

# 写路径越界检查：1/true 启用（dev 模板默认常关，以模板为准）
# OMLXCLI_EXEC_ENFORCE_WORKSPACE_BOUNDARY=

# 非空时：命令行须匹配该正则子串才允许执行（白名单）
# OMLXCLI_EXEC_ALLOWLIST_RE=
#
# sudo：Web 执行器无 TTY，模型触发的 sudo 需在「确认执行」弹窗填写一次性密码（经 sudo -S 走 stdin，不落库）。
# 长期免密可为本机账户配置 sudoers NOPASSWD（仅限可信命令路径）。

# -----------------------------------------------------------------------------
# 八、管理 / 审计
# -----------------------------------------------------------------------------
# 设置后启用 GET /api/admin/sessions/{id}/audit-export，请求头 X-Admin-Token 须一致
# OMLXCLI_ADMIN_TOKEN=

# -----------------------------------------------------------------------------
# 九、测试与 CI（一般仅 CI 或本机刻意设置）
# -----------------------------------------------------------------------------
# 为 1/true/yes/on 时跳过 needs_outbound_http 类 agent 评测（避免外网抖动）
# OMLXCLI_EVAL_SKIP_HTTP=

# --- 九·1、全技能冒烟 scripts/smoke_all_skills.py（与「四」skills 同机 Python 进程读取）---
# 脚本会 load_dotenv：本段写在 .env.local 亦可；见 Skills_README.md §8.1。
#
# 为 1/true/yes/on 时：启用 weather_*、web_read 等外网用例（仍受上游可用性影响）。
# OMLXCLI_SMOKE_NETWORK=1
# 为 1/true/yes/on 时：启用股票技能冒烟（stock_*）。默认建议关闭，避免东财风控造成误报。
# OMLXCLI_SMOKE_STOCK=1
#
# 下列均为「绝对路径」样例文件；不设则对应 PDF / vision / audio / video 技能在冒烟中为 SKIP（非失败）。
# OMLXCLI_SMOKE_PDF_PATH=/绝对路径/样例.pdf
# OMLXCLI_SMOKE_IMAGE_PATH=/绝对路径/样例.png
# OMLXCLI_SMOKE_AUDIO_PATH=/绝对路径/样例.m4a
# OMLXCLI_SMOKE_VIDEO_PATH=/绝对路径/样例.mp4
#
# web_search：需「第五节」已配置 OMLXCLI_SEARCH_GATEWAY_* 或 OMLXCLI_SEARXNG_URL，且通常与 OMLXCLI_SMOKE_NETWORK=1 同开。
# web_read：需 OMLXCLI_SMOKE_NETWORK=1，且 OMLXCLI_EVAL_SKIP_HTTP 不能为 1/true（否则脚本按 CI 语义 SKIP）。
# vision_describe / vision_compare / audio_transcribe / video_summarize：除样例路径外还需下列三键（与「十」同名）；未配置时脚本 SKIP，非 FAIL。
# 【冒烟测试用】全技能冒烟 scripts/smoke_all_skills.py：取消注释并填占位；真密钥只放本机 .env.local，勿提交仓库。
# _AICLI_API_BASE=
# _AICLI_API_KEY=
# _AICLI_LLM_MODEL=
# --- Excel / CSV / docx 等新技能如何冒烟（本节无专用 PATH 变量）---
# csv_tsv_summary：脚本写入 .omlxcli/_smoke_sample.csv 后调用；仅需标准库 + 仓库根。
# xlsx_sample：脚本用 openpyxl 生成 .omlxcli/_smoke_sample.xlsx 后调用；须已 pip 安装 openpyxl（见 requirements.txt），否则冒烟为 SKIP。
# docx_to_text：脚本用 python-docx 生成 .omlxcli/_smoke_sample.docx；缺 python-docx 时为 SKIP。
# structured_pick：读仓库根 OI_TOOL_MAP.json（缺文件则 SKIP，可先 python3 scripts/gen_oi_tool_map.py --write）。
# git_snapshot：对仓库根 __ROOT__ 执行只读 git log，无需样例路径。
# 音频/视频含转写：Apple Silicon 建议用 .venv（requirements 条件安装 mlx-whisper）执行：.venv/bin/python scripts/smoke_all_skills.py
#
# --- 股票行情 skills（stock_quote / stock_brief）可选网络参数 ---
# 背景：东财行情域名 push2.eastmoney.com 在部分网络出口会被风控/限流，表现为
#      RemoteDisconnected: Remote end closed connection without response。
# 说明：以下代理仅用于股票 skills 的东财请求；若不配置，将直连并在失败时自动回退新浪源。
# 优先级：OMLXCLI_STOCK_EASTMONEY_PROXY > OMLXCLI_STOCK_PROXY
# 示例（本机 Clash）：
# OMLXCLI_STOCK_EASTMONEY_PROXY=http://127.0.0.1:7890
# 通用兜底代理（给股票 skills 预留；当前东财请求也会读取此变量）
# OMLXCLI_STOCK_PROXY=http://127.0.0.1:7890
# 仅东财行情接口代理（推荐优先设置这个，影响范围最小）
# OMLXCLI_STOCK_EASTMONEY_PROXY=http://127.0.0.1:7890
# 自动解封逻辑已内置：请求失败后会先 checkuser 判断是否 block=true，再尝试执行仓库内置解封脚本（无需额外配置）。

# -----------------------------------------------------------------------------
# 十、仅手动调试 skills（无 Web 会话、直接跑 Python 子进程时）
# -----------------------------------------------------------------------------
# Web 内 run_skill 由 session_engine 注入 _AICLI_*；脱离 Web 时可在 shell 或 .env.local 中 export（见 .omlxcli/skills/_media.py）。
# 下列前三项与「九·1」【冒烟测试用】为同一套键；全技能冒烟填「九·1」或本节均可（勿重复取消注释两套不同值）。
# 【冒烟测试用】vision_* / audio_transcribe / video_summarize 等需 LLM 的 skill。
# _AICLI_API_BASE=
# _AICLI_API_KEY=
# _AICLI_LLM_MODEL=
# _AICLI_STT_MODEL=
# 语音权重备选（无 _AICLI_STT_MODEL 时）：OI_STT_MODEL=

# -----------------------------------------------------------------------------
# 十一、Claude Code Job（可选，macOS 本机优先）
# -----------------------------------------------------------------------------
# 对话中 run_skill 可调 claude_job_start / status / logs / cancel；子进程为官方 CLI「claude -p」。
# 日志与元数据在 OMLXCLI_DATA_DIR/claude-jobs/；UI「Claude 任务」只读轮询。
# 未同时满足下列项时 skills 与 REST 列表会不可用（见 GET /api/claude-code/status）。
#
# OMLXCLI_ENABLE_CLAUDE_CODE=1
# OMLXCLI_CLAUDE_CODE_API_KEY=sk-ant-api03-YOUR_API_KEY 或 DeepSeek Key（服务会注入 ANTHROPIC_AUTH_TOKEN）
# 可选：自定义 Anthropic 兼容 Base（默认官方）
# OMLXCLI_CLAUDE_CODE_ANTHROPIC_BASE_URL=https://api.anthropic.com
# 可选：Claude Code 主模型（通过 ANTHROPIC_MODEL 注入；不再强制拼 --model）
# OMLXCLI_CLAUDE_CODE_MODEL=claude-sonnet-4-20250514
# DeepSeek 推荐：deepseek-v4-pro[1m]
# OMLXCLI_CLAUDE_CODE_DEFAULT_HAIKU_MODEL=deepseek-v4-flash
# OMLXCLI_CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash
# OMLXCLI_CLAUDE_CODE_EFFORT_LEVEL=max
# 可选：headless 预批准工具，逗号分隔（示例）
# OMLXCLI_CLAUDE_CODE_ALLOWED_TOOLS=Read,Edit,Bash
# 可选：单任务日志文件大小上限（字节，默认 5242880=5MB；超限后保留尾部）
# OMLXCLI_CLAUDE_JOB_MAX_LOG_BYTES=5242880
# 可选：终态任务日志保留秒数（默认 1209600=14天；超期自动清理）
# OMLXCLI_CLAUDE_JOB_LOG_RETENTION_SEC=1209600
# 可选：是否为 claude_job_start 注入结构化报告模板（默认 1 开启，提升输出稳定性）
# OMLXCLI_CLAUDE_JOB_STRICT_REPORT=1
# 可选：后台回收 running 状态间隔秒（默认 15；用于自动纠正僵尸 running）
# OMLXCLI_CLAUDE_JOB_REAPER_INTERVAL_SEC=15
#
# 本机须已安装：npm i -g @anthropic-ai/claude-code（命令 claude 在 PATH 中）。
